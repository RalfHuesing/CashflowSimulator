<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CashflowSimulator.Desktop.Features.Analysis"
             xmlns:controls="using:CashflowSimulator.Desktop.Common.Controls"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="CashflowSimulator.Desktop.Features.Analysis.AnalysisDashboardView"
             x:DataType="vm:AnalysisDashboardViewModel">

    <controls:FeatureLayoutView Title="Analyse &amp; Auswertung"
                                Description="Plausibilitätsprüfung: Gesamtvermögen im Zeitverlauf und jährliche Aggregation mit Monats-Drill-Down.">
        <Grid RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" IsVisible="{Binding IsEmpty}" Spacing="8" Margin="0,0,0,16">
                <TextBlock Text="Keine Simulationsdaten vorhanden."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14"/>
                <TextBlock Text="Bitte zuerst eine Simulation starten, um die Analyse anzuzeigen."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"/>
            </StackPanel>

            <Grid Grid.Row="0" Grid.RowSpan="2" IsVisible="{Binding !IsEmpty}" RowDefinitions="280, 8, *">
                <Border Grid.Row="0" Background="{StaticResource ContentBackgroundBrush}" Padding="8" CornerRadius="4">
                    <lvc:CartesianChart Series="{Binding TotalAssetsSeries}"
                                        Height="260"
                                        VerticalAlignment="Top"/>
                </Border>
                <controls:MasterDetailView Grid.Row="2">
                    <controls:MasterDetailView.MasterContent>
                        <DataGrid ItemsSource="{Binding YearlySummaries}"
                                  SelectedItem="{Binding SelectedYearlySummary}"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  MinHeight="120">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Jahr" Width="80" Binding="{Binding YearIndex}"/>
                                <DataGridTemplateColumn Header="Liquidität (Jahresende)" Width="140" SortMemberPath="EndCashBalance">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EndCashBalance, StringFormat='{}{0:N2}'}"
                                                       TextAlignment="Right"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Gesamtvermögen (Jahresende)" Width="180" SortMemberPath="EndTotalAssets">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EndTotalAssets, StringFormat='{}{0:N2}'}"
                                                       TextAlignment="Right"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </controls:MasterDetailView.MasterContent>
                    <controls:MasterDetailView.DetailContent>
                        <Grid RowDefinitions="Auto, *, Auto, Auto">
                            <TextBlock Grid.Row="0" Text="Monate im ausgewählten Jahr" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding MonthsInSelectedYear}"
                                      SelectedItem="{Binding SelectedMonth}"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      MinHeight="80">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Monat" Width="70" Binding="{Binding MonthIndex}"/>
                                    <DataGridTemplateColumn Header="Alter" Width="80" SortMemberPath="Age">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Age, StringFormat='{}{0:F2}'}"
                                                           TextAlignment="Right"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Liquidität" Width="100" SortMemberPath="CashBalance">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding CashBalance, StringFormat='{}{0:N2}'}"
                                                           TextAlignment="Right"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Gesamtvermögen" Width="120" SortMemberPath="TotalAssets">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TotalAssets, StringFormat='{}{0:N2}'}"
                                                           TextAlignment="Right"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Grid.Row="2" Text="Einzelbuchungen (ausgewählter Monat)" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <ItemsControl Grid.Row="3" ItemsSource="{Binding SelectedMonth.CashflowSnapshots}" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" MinWidth="120"/>
                                            <TextBlock Text="{Binding Amount, StringFormat='{}{0:N2}'}"/>
                                            <TextBlock Text="{Binding CashflowType, Converter={StaticResource EnumDescriptionConverter}, Mode=OneWay}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </controls:MasterDetailView.DetailContent>
                </controls:MasterDetailView>
            </Grid>
        </Grid>
    </controls:FeatureLayoutView>
</UserControl>
